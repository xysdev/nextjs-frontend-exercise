{
  "name": "nextjs-frontend-exercise",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm run lint:js && pnpm run lint:style",
    "lint:fix": "pnpm run lint:js:fix && pnpm run lint:style:fix",
    "lint:js": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:js:fix": "eslint . --fix --report-unused-disable-directives --max-warnings 0",
    "lint:style": "stylelint 'src/**/*.{ts,tsx,css,scss}'",
    "lint:style:fix": "stylelint --fix 'src/**/*.{ts,tsx,css,scss}'",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:fix": "vitest run -u",
    "test:coverage": "vitest run --coverage",
    "test:staged": "vitest related --run",
    "test:watch": "vitest --watch",
    "test:watch:coverage": "vitest --watch --coverage",
    "typecheck": "tsc --noEmit",
    "zip": "git archive HEAD -o $(basename $PWD).zip && mv $(basename $PWD).zip ../dist"
  },
  "dependencies": {
    "next": "^16.1.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@next/eslint-plugin-next": "^16.1.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-istanbul": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/eslint-plugin": "^1.6.6",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-compat": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.0.0",
    "happy-dom": "20.3.4",
    "postcss": "^8.5.6",
    "postcss-styled-syntax": "^0.7.1",
    "prettier": "^3.8.0",
    "stylelint": "^17.0.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.17"
  },
  "overrides": {
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3"
  },
  "packageManager": "pnpm@10.28.1",
  "browserslist": [
    "> 0.5% in NL"
  ]
}
